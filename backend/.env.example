# ============================================================
# GradPath Backend — Environment Variables
# Copy to .env and fill in values.
# ============================================================

# ── Database ──
# 安全提示 (FASTAPI-DEPLOY-002): 请生成强密码，切勿使用 changeme / password 等弱密码
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=<replace-with-strong-password>
POSTGRES_USER=gradpath
POSTGRES_DB=gradpath
# 注意: docker-compose 会用上面的 POSTGRES_PASSWORD 覆盖 DATABASE_URL 中的密码
# 本地非 docker 运行时，请把 DATABASE_URL 中的密码替换为与 POSTGRES_PASSWORD 一致的值
DATABASE_URL=postgresql://gradpath:${POSTGRES_PASSWORD}@localhost:5432/gradpath

# ── Redis ──
# 安全提示 (FASTAPI-DEPLOY-002): 生产环境必须设置 Redis 密码
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
REDIS_PASSWORD=<replace-with-strong-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@localhost:6379/0

# ── Security ──
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=<replace-with-random-64-char-string>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Environment (development / staging / production) ──
ENVIRONMENT=development

# ── Logging ──
LOG_LEVEL=INFO

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM Config ──
LLM_API_KEY=<your-api-key>
LLM_MODEL=glm-4
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ── Redis (optional, for caching) ──
# 注: 上方 REDIS_URL 已包含密码；如不需要密码认证，可改用下方 URL（仅本地开发）
# REDIS_URL=redis://localhost:6379/0

# ── Firecrawl API Key (optional, 用于高级爬虫功能) ──
FIRECRAWL_API_KEY=
